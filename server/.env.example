# ngNailArt backend — ortam değişkenleri
# Bu dosyayı ".env" olarak kopyalayıp anahtarlarınızı girin. .env git'e gönderilmez.

PORT=3000

# Veritabanı
# YEREL/HIZLI: SQLite (harici sunucu gerektirmez). Dosya: prisma/dev.db
DATABASE_URL="file:./dev.db"
# YAYIN (kalıcı): PostgreSQL. schema.prisma'da provider'ı "postgresql" yap ve şu satırı kullan:
# DATABASE_URL="postgresql://kullanici:sifre@host:5432/veritabani?sslmode=require"

# Çalışma modu. Yayında "production" OLMALI: demo OTP/kod sızıntısı kapanır, CORS allowlist
# devreye girer, zayıf JWT_SECRET ile başlatma durur, demo sipariş plan/kredi vermez.
NODE_ENV=development

# Uygulamanın herkese açık adresi (ödeme dönüşü/e-posta linkleri + CORS için). Yayında ZORUNLU.
# APP_URL=https://miraclenailart.onrender.com
# CORS: ek izinli origin(ler), virgülle ayır (özel alan adı vb.). Boşsa APP_URL kullanılır.
# ALLOWED_ORIGINS=https://miraclenailart.com,https://www.miraclenailart.com

# En az birini doldurun (gerçek AI için). Boş bırakırsanız backend çalışır ama
# /api/ai/* çağrıları 503 döner ve frontend demo/prosedürel görsele düşer.

# Google Gemini + Imagen 3  (paket:  npm i @google/genai)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI GPT + DALL·E 3  (paket:  npm i openai)
OPENAI_API_KEY=your-openai-api-key-here
AI_MODEL=gpt-4.1-mini
DALLE_MODEL=dall-e-3

# Replicate / Flux 1.1 Pro (GERÇEK kullanıcı görsel üretimi)  (paket:  npm i replicate)
REPLICATE_API_TOKEN=your-replicate-api-token-here

# fal.ai / FLUX 1.1 Pro (GERÇEK görsel üretimi — TERCİH EDİLEN, paket GEREKMEZ, HTTP ile).
# Anahtar "id:secret" biçimindedir. fal.ai panelinden alınır.
FAL_KEY=your-fal-key-here

# ---------------------------------------------------------------------------
# ÖDEME — iyzico  (paket:  npm i iyzipay)
# Test: sandbox-merchant.iyzipay.com'dan sandbox anahtarları + URI = sandbox.
# Canlı: gerçek anahtarlar + IYZICO_URI=https://api.iyzipay.com
IYZICO_API_KEY=sandbox-your-api-key
IYZICO_SECRET=sandbox-your-secret-key
IYZICO_URI=https://sandbox-api.iyzipay.com
# (Alternatif ödeme) Stripe / PayTR — kullanmıyorsan boş bırak
# STRIPE_SECRET_KEY=sk_...
# PAYTR_MERCHANT_ID=...
# PAYTR_MERCHANT_KEY=...
# PAYTR_MERCHANT_SALT=...

# ---------------------------------------------------------------------------
# SMS / OTP — TWILIO  (paket:  npm i twilio)
# twilio.com > Console panosundan al. Boş bırakırsan OTP demo modda çalışır.
# Deneme (trial) hesabında SMS yalnızca DOĞRULANMIŞ numaralara gider.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM=+1XXXXXXXXXX

# (Alternatif SMS) Netgsm — kullanmıyorsan boş bırak
# NETGSM_USER=...
# NETGSM_PASS=...
# NETGSM_HEADER=ONAYLI-BASLIK

# JWT (oturum imzalama) — EN AZ 16 karakter uzun rastgele metin.
# ÜRETİMDE zayıf/varsayılan/boş olursa sunucu BAŞLAMAZ (fail-fast).
JWT_SECRET=degistir-bunu-uzun-rastgele-bir-anahtarla

# ---------------------------------------------------------------------------
# E-POSTA (şifre sıfırlama + hesap silme onayı)
# ÖNERİLEN: Brevo HTTP API — Render'da SMTP portları kapalı olduğu için tek çalışan yol.
# ÜRETİMDE ZORUNLU (yoksa reset/silme kodu demo olur ve üretimde yanıtta DÖNMEZ).
# BREVO_API_KEY=xkeysib-...
# BREVO_SENDER=no-reply@miraclenailart.com   # Brevo'da DOĞRULANMIŞ gönderen e-postası
#
# (Alternatif) SMTP — yalnızca yerel geliştirmede; Render'da çalışmaz.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_FROM=Miracle Nail Art <no-reply@ornek.com>
