{
  "name": "ngnailart-server",
  "version": "0.1.0",
  "private": true,
  "description": "ngNailArt backend — Express + çok sağlayıcılı AI + Prisma",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "node prisma/seed.js",
    "db:setup": "prisma generate && prisma migrate dev --name init && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.0.0",
    "jsonwebtoken": "^9.0.2"
  },
  "optionalDependencies": {
    "iyzipay": "^2.0.0",
    "stripe": "^16.0.0",
    "twilio": "^5.0.0",
    "nodemailer": "^6.9.0",
    "openai": "^4.0.0",
    "@google/genai": "^0.3.0",
    "replicate": "^0.34.0"
  },
  "devDependencies": {
    "prisma": "^5.0.0"
  }
}
